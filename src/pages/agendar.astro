---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
---

<BaseLayout title="Agendar Hora | Psycho-logic" description="Reserva tu sesión de terapia online. Elige el día y la hora que mejor se adapte a ti.">
  <Navbar />
  
  <main class="min-h-screen pt-32 pb-20 relative overflow-hidden flex flex-col">
    <!-- Decoración de fondo suave -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-sage-100 rounded-full mix-blend-multiply filter blur-[80px] opacity-70 animate-pulse" style="animation-duration: 8s; z-index: -1;"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-primary/10 rounded-full mix-blend-multiply filter blur-[80px] opacity-70 animate-pulse" style="animation-duration: 10s; z-index: -1;"></div>

    <div class="container mx-auto px-6 max-w-5xl relative z-10 w-full flex-grow flex flex-col items-center justify-center">
      <div class="text-center mb-10 mt-8">
        <h1 class="text-3xl md:text-5xl font-semibold text-foreground mb-4 tracking-tight">Reserva tu sesión online</h1>
        <p class="text-zinc-600 text-lg max-w-2xl mx-auto">Elige el día y la hora que mejor se adapte a ti.</p>
      </div>

      <!-- Contenedor Glassmorfismo para el iframe -->
      <div class="bg-white/40 backdrop-blur-md rounded-3xl shadow-sm border border-white/20 p-4 md:p-8 w-full max-w-4xl mx-auto mb-16">
        <!-- Ejemplo de iframe responsivo (Cal.com / TidyCal) -->
        <div class="relative w-full h-[650px] md:h-[700px] rounded-2xl overflow-hidden bg-white/50 border border-white/40">
          <iframe 
            src="https://cal.com/link-de-ejemplo" 
            class="w-full h-full border-0 rounded-xl" 
            title="Agendar cita"
            loading="lazy"
          ></iframe>
        </div>
        <p class="text-center text-xs text-zinc-400 mt-4">
          * Para modificar el calendario, cambia el enlace `src` dentro del &lt;iframe&gt; en el código.
        </p>
      </div>
    </div>
  </main>
  
  <Footer />
</BaseLayout>
