---
// src/components/shared/TrustBanner.astro
const specialties = [
  "Terapia Cognitivo-Conductual",
  "Gestión de Ansiedad",
  "Mindfulness",
  "Regulación Emocional",
  "Terapia de Pareja"
];
---

<section class="w-full border-y border-zinc-200/50 bg-white/30 backdrop-blur-sm py-10">
  <div class="container mx-auto px-6 max-w-5xl">
    <p class="text-center text-xs font-semibold text-zinc-400 mb-6 uppercase tracking-[0.2em]">
      Enfoques Clínicos y Especialidades
    </p>
    
    <div class="flex flex-wrap justify-center items-center gap-x-10 md:gap-x-16 gap-y-6">
      {specialties.map((specialty) => (
        <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity duration-300 cursor-default">
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm-1.177-7.86l-2.765-2.767L7 12.431l3.118 3.121 8.824-8.822-1.061-1.061-7.763 7.763z"/>
          </svg>
          <span class="text-base md:text-lg font-medium text-zinc-700 tracking-tight">{specialty}</span>
        </div>
      ))}
    </div>
  </div>
</section>
