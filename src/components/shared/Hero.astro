---
// src/components/shared/Hero.astro
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden min-h-[90vh] flex items-center">
  
  <!-- Imagen de fondo con filtro de color (Color Terroso) -->
  <div class="absolute inset-0 z-0">
    <img src="/bg-hero.jpg" alt="Sesión de terapia" class="w-full h-full object-cover" />
    <!-- Filtro sólido semitransparente para dar el tono arena a la imagen -->
    <div class="absolute inset-0 bg-background/70 mix-blend-multiply"></div>
    <!-- Gradiente que hace que el texto de la izquierda sea perfectamente legible -->
    <div class="absolute inset-0 bg-gradient-to-r from-background via-background/90 to-background/30"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-8 items-center">
      
      <!-- Lado Izquierdo: Texto (Alineado a la izquierda) -->
      <div class="flex flex-col items-start text-left">
        <!-- Etiqueta superior -->
        <span class="inline-block py-1.5 px-4 rounded-full bg-sage-50 border border-sage-200 text-primary text-sm font-medium mb-8 shadow-sm">
          Atención Psicológica 100% Online
        </span>
        
        <!-- Título Principal -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold text-foreground leading-[1.1] mb-6 tracking-tight">
          Un espacio seguro para tu <span class="text-primary relative whitespace-nowrap">bienestar mental<svg class="absolute -bottom-2 left-0 w-full h-3 text-sage-200 -z-10 opacity-70" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="6" fill="transparent"/></svg></span>,<br /> desde casa.
        </h1>
        
        <!-- Subtítulo -->
        <p class="text-lg md:text-xl text-zinc-800 mb-10 leading-relaxed font-medium max-w-xl">
          Inicia tu proceso terapéutico con empatía, profesionalismo y total confidencialidad. Da el primer paso hacia la tranquilidad que buscas sin salir de tu hogar.
        </p>
        
        <!-- Botones de Acción (CTA) -->
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
          <a 
            href="/agendar" 
            class="w-full sm:w-auto px-8 py-4 text-base font-medium rounded-3xl bg-primary text-primary-foreground hover:bg-primary-hover shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-1 transition-all duration-300 flex justify-center items-center gap-2"
          >
            Agendar Cita Online
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a 
            href="#sobre-mi" 
            class="w-full sm:w-auto px-8 py-4 text-base font-medium rounded-3xl bg-white/60 backdrop-blur-md border border-white/40 text-zinc-800 hover:bg-white shadow-sm hover:shadow-md transition-all duration-300 text-center"
          >
            Conocer más
          </a>
        </div>

        <!-- Avatares de Prueba Social Mini -->
        <div class="mt-10 flex items-center gap-4">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full border-2 border-white bg-zinc-200 flex items-center justify-center overflow-hidden"><img src="https://i.pravatar.cc/100?img=1" alt="Paciente" /></div>
            <div class="w-10 h-10 rounded-full border-2 border-white bg-zinc-200 flex items-center justify-center overflow-hidden"><img src="https://i.pravatar.cc/100?img=2" alt="Paciente" /></div>
            <div class="w-10 h-10 rounded-full border-2 border-white bg-zinc-200 flex items-center justify-center overflow-hidden"><img src="https://i.pravatar.cc/100?img=3" alt="Paciente" /></div>
          </div>
          <div class="text-sm text-zinc-700 font-medium">
            Únete a más de <span class="font-bold text-zinc-900">200 personas</span><br/>que mejoraron su vida.
          </div>
        </div>
      </div>

      <!-- Lado Derecho: Tarjetas Flotantes sobre la Imagen de Fondo -->
      <div class="relative w-full h-[400px] lg:h-[650px] mt-10 lg:mt-0 flex items-center justify-center">

        <!-- Tarjeta Flotante 1: Testimonio (Arriba a la izquierda) -->
        <div class="absolute top-10 -left-2 lg:-left-12 bg-white/90 backdrop-blur-md p-4 rounded-2xl shadow-xl border border-white/50 animate-[bounce_5s_infinite] transition-transform hover:scale-105 z-20">
          <div class="flex items-center gap-1 mb-1 text-amber-400">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <p class="text-sm font-semibold text-zinc-800">"Excelente profesional"</p>
          <p class="text-xs text-zinc-500 mt-1">Me ayudó a encontrar mi paz.</p>
        </div>

        <!-- Tarjeta Flotante 2: Estadísticas (Abajo a la derecha) -->
        <div class="absolute bottom-16 -right-2 lg:-right-8 bg-white/90 backdrop-blur-md p-4 rounded-2xl shadow-xl border border-white/50 animate-[bounce_6s_infinite_reverse] transition-transform hover:scale-105 flex items-center gap-4 z-20">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xl font-bold text-zinc-800">+500</p>
            <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider">Pacientes<br/>Atendidos</p>
          </div>
        </div>

        <!-- Tarjeta Flotante 3: Certificado (Mitad derecha) -->
        <div class="absolute top-1/2 -translate-y-1/2 -right-4 lg:-right-12 bg-white/90 backdrop-blur-md px-5 py-3 rounded-2xl shadow-xl border border-white/50 animate-[bounce_4s_infinite] flex items-center gap-3 z-20 transition-transform hover:scale-105">
          <div class="text-primary bg-primary/10 p-2 rounded-full">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 5.09L19.18 5.18L19.27 9.27L22.36 12.36L19.27 15.45L19.18 19.55L15.09 19.64L12 22.73L8.91 19.64L4.82 19.55L4.73 15.45L1.64 12.36L4.73 9.27L4.82 5.18L8.91 5.09L12 2ZM11 16L16 11L14.59 9.58L11 13.17L9.41 11.59L8 13L11 16Z"/></svg>
          </div>
          <p class="text-xs font-semibold text-zinc-800 tracking-wide uppercase">Psicólogo<br/>Clínico</p>
        </div>
        
      </div>
    </div>
  </div>
</section>
