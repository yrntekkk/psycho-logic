# ==========================================
# Configuración Flow.cl (Pasarela de Pagos)
# ==========================================
# URL de la API de Flow (Usa sandbox para pruebas y producción cuando lances)
# Sandbox: https://sandbox.flow.cl/api
# Producción: https://www.flow.cl/api
FLOW_API_URL="https://sandbox.flow.cl/api"

# Credenciales de Flow (Obtenlas en flow.cl -> Integración)
FLOW_API_KEY="tu_api_key_de_flow"
FLOW_SECRET_KEY="tu_secret_key_de_flow"

# ==========================================
# Configuración de Google Calendar API
# ==========================================
# Correo de la Service Account creada en Google Cloud Console
GOOGLE_CLIENT_EMAIL="tu-service-account@tu-proyecto.iam.gserviceaccount.com"

# Clave privada de la Service Account (Reemplaza los saltos de línea con \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIICdQIBADANBgk...\n-----END PRIVATE KEY-----\n"

# El correo del calendario destino (generalmente el correo principal de tu cliente o el ID del calendario)
# IMPORTANTE: Debes compartir el calendario en las configuraciones de Google Calendar con la GOOGLE_CLIENT_EMAIL dándole permisos para "Hacer cambios en eventos".
GOOGLE_CALENDAR_ID="correo_del_psicologo@gmail.com"

# ==========================================
# Configuración de la App
# ==========================================
# URL pública de tu sitio para los webhooks y redirecciones (usar localhost para pruebas locales)
PUBLIC_SITE_URL="http://localhost:4321"
